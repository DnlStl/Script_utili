#!/bin/bash

# --- CONFIGURAZIONE COLORI ---
# Utilizzati per rendere l'output nel terminale leggibile e distinguere i fix
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color (reset)

solve_typing_issues() {
    local input_text="$1"
    local lang="$2"
    local corrected_text=""
    local error_count=0
    local last_word=""

    # 1. DIZIONARIO PERSONALIZZATO (MAPPA DEI FIX MANUALI)
    # Questa è la "Cintura Nera" dello script. Le parole qui dentro hanno la priorità assoluta.
    # Serve a proteggere slang, comandi SQL/Bash e nomi propri dalle allucinazioni di Aspell.
    declare -A manual_fixes
    manual_fixes=( 
        ["vbomer"]="bomber" ["alero"]="albero" ["caco"]="caco" 
        ["git"]="git" ["sudo"]="sudo" ["caio"]="ciao" ["caoi"]="ciao" 
        ["ciop"]="ciao" ["comsi"]="così" ["comsa"]="cosà" 
        ["vecio"]="vecio" ["log"]="log" ["reboot"]="reboot" 
        ["python"]="python" ["bash"]="bash" ["sauzer"]="sauzer" 
        ["selce"]="select" ["rom"]="from" ["ue"]="ue" ["pc"]="pc"
        ["grep"]="grep" ["kernel"]="kernel" ["panic"]="panic" ["loot"]="loot"
        ["droppato"]="droppato" ["pushato"]="pushato" ["commit"]="commit"
        ["rebooto"]="rebooto" ["perché"]="perché" ["perche"]="perché"
        ["fasso"]="fasso" ["funzia"]="funzia" ["magnar"]="magnar" ["switcho"]="switcho"
    )

    # 2. RIMOZIONE BALBETII (DEDUPLICAZIONE INIZIALE)
    # Usa sed per trovare parole identiche consecutive (es. "ciao ciao") e ne tiene solo una.
    input_text=$(echo "$input_text" | sed -E 's/\b([a-zA-Z]+)\s+\1\b/\1/gI')

    # 3. SPLIT DEL TESTO IN ARRAY
    # Converte la stringa in una lista di parole su cui cicliamo.
    read -r -a words <<< "$input_text"

    for (( i=0; i<${#words[@]}; i++ )); do
        word="${words[$i]}"

        # --- 4. FILTRO ANTIBOMBA (PROTEZIONE TECNICA) ---
        # Questa Regex controlla se la parola contiene caratteri "non alfabetici" (es: / . | > - ").
        # Se li trova, assume che sia un comando o un percorso file e NON lo processa.
        # Eccezione: permette la punteggiatura standard alla fine della parola (es: "ciao!").
        if [[ "$word" =~ [^a-zA-ZàèéìòùÀÈÉÌÒÙ] && ! "$word" =~ ^[a-zA-ZàèéìòùÀÈÉÌÒÙ]+[[:punct:]]$ ]]; then
            suggestion="$word"
        else
            # Pulizia per il controllo: rimuove punteggiatura finale per non confondere Aspell
            clean_word=$(echo "$word" | sed "s/[[:punct:]]*$//")
            lower_word=$(echo "$clean_word" | tr '[:upper:]' '[:lower:]')

            suggestion=""

            # A. CONTROLLO MAPPA MANUALE
            # Se la parola è nel nostro dizionario personalizzato, usiamo quella versione.
            if [[ -n "${manual_fixes[$lower_word]}" ]]; then
                suggestion="${manual_fixes[$lower_word]}"
                # Recupera la punteggiatura originale (es: "vecio," -> virgola preservata)
                punct=$(echo "$word" | sed "s/[a-zA-Z0-9àèéìòùÀÈÉÌÒÙ]//g")
                suggestion="${suggestion}${punct}"

            # B. CONTROLLO ASPELL (IL CORRETTORE)
            # Solo per parole lunghe più di 3 caratteri (evita di distruggere congiunzioni o abbreviazioni).
            elif [[ ${#clean_word} -gt 3 ]]; then
                # Controlla se la parola è corretta nel dizionario di sistema
                check=$(echo "$clean_word" | aspell -a -l "$lang" 2>/dev/null | grep -E '^\*|^\+')
                if [[ -z "$check" ]]; then
                    # Se errata, prende il primo suggerimento utile di Aspell
                    raw_suggestions=$(echo "$clean_word" | aspell -a -l "$lang" --sug-mode=normal 2>/dev/null | grep '&' | awk -F': ' '{print $2}')
                    suggestion=$(echo "$raw_suggestions" | tr ',' '\n' | sed 's/^[[:space:]]*//' | head -n 1)
                    # Riattacca la punteggiatura originale
                    punct=$(echo "$word" | sed "s/[a-zA-Z0-9àèéìòùÀÈÉÌÒÙ]//g")
                    suggestion="${suggestion}${punct}"
                else
                    # Parola già corretta
                    suggestion="$word"
                fi
            else
                # Parola troppo corta per Aspell (es: "ue", "pc")
                suggestion="$word"
            fi
        fi

        # Fallback di sicurezza: se tutto fallisce, tieni la parola originale
        [ -z "$suggestion" ] && suggestion="$word"

        # 5. DEDUPLICAZIONE POST-CORREZIONE
        # Evita che correzioni diverse portino alla stessa parola ripetuta (es: "caio ciao" -> "ciao ciao" -> "ciao")
        clean_sug=$(echo "$suggestion" | tr '[:upper:]' '[:lower:]' | sed "s/[[:punct:]]//g")
        if [[ "$clean_sug" == "$last_word" && -n "$clean_sug" ]]; then
            ((error_count++))
            continue
        fi
        last_word="$clean_sug"

        # 6. GESTIONE MAIUSCOLE
        # Capitalizza la prima parola della frase, a meno che non sia un comando o un nick protetto.
        if [[ $i -eq 0 && ! "$suggestion" =~ ^(source|git|sudo|select|from|python|sauzer|fasso|switcho)$ ]]; then
            suggestion="$(tr '[:lower:]' '[:upper:]' <<< ${suggestion:0:1})${suggestion:1}"
        fi

        # 7. LOG DELLE MODIFICHE E COSTRUZIONE OUTPUT
        if [[ "${suggestion,,}" != "${word,,}" ]]; then
            # Parola modificata: evidenziata in giallo e loggata
            corrected_text="${corrected_text}${YELLOW}${suggestion}${NC} "
            ((error_count++))
            echo -e "${RED}[FIX]${NC} '$word' -> '${suggestion}'" >&2
        else
            # Parola originale: aggiunta normalmente
            corrected_text="${corrected_text}${suggestion} "
        fi
    done

    # 8. STAMPA RISULTATI FINALI
    echo -e "\n${CYAN}--- TESTO FINALE ---${NC}"
    echo -e "$corrected_text" | sed 's/[[:space:]]*$//'
    echo -e "\n${BLUE}Totale correzioni effettuate: $error_count${NC}"
}

# --- LOGICA DI AVVIO ---
echo -e "${BLUE}Lingua (1: it, 2: en):${NC}"
read -p "> " lang_choice
[[ "$lang_choice" == "2" ]] && LANG="en" || LANG="it"

echo -n "Testo: "
# 'read -r' preserva i backslash, utile per input tecnici
read -r user_input
[ -n "$user_input" ] && solve_typing_issues "$user_input" "$LANG"
