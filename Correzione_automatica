#!/bin/bash

# --- CONFIGURAZIONE COLORI ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

solve_typing_issues() {
    local input_text="$1"
    local lang="$2"
    local lang_choice="$3" # Passiamo la scelta per la logica dei doppioni
    local corrected_text=""
    local error_count=0

    declare -A manual_fixes
    manual_fixes+=( ["reboot"]="reboot" ["nas"]="NAS" ["db"]="db" ["droppato"]="droppato" ["pushato"]="pushato" ["log"]="log" ["python"]="python" ["bash"]="bash" ["root"]="root" ["grep"]="grep" ["ghz"]="Ghz" )
    manual_fixes+=( ["caio"]="ciao" ["caoi"]="ciao" ["caoio"]="ciao" ["caaios"]="ciao" ["coem"]="come" ["av"]="va" ["stai"]="stai" ["perche"]="perchĂ©" ["daje"]="daje" )
    manual_fixes+=( ["vecio"]="vecio" ["fasso"]="fasso" ["xe"]="xe" ["go"]="go" ["piantĂ "]="piantĂ " ["magnar"]="magnar" ["funzia"]="funzia" ["mona"]="mona" ["ostia"]="ostia" ["sbalio"]="sbaglio" ["ndemo"]="ndemo" ["demo"]="demo" ["ghe"]="ghe" ["pi"]="pi" ["bae"]="bae" ["si"]="si" ["svangata"]="svangata" )
    manual_fixes+=( ["sauzer"]="Sauzer" ["richie"]="Richie" ["michel"]="Michel" ["ciccio"]="Ciccio" )

    # --- DEDUPLICAZIONE SOLO PER LINGUA 1 E 2 ---
    if [[ "$lang_choice" != "3" ]]; then
        input_text=$(echo "$input_text" | sed -E 's/\b([a-zA-ZĂ Ă¨Ă©Ă¬Ă²Ă¹Ă€ĂˆĂ‰ĂŒĂ’Ă™]+)\s+\1\b/\1/gI')
    fi

    read -r -a words <<< "$input_text"

    for (( i=0; i<${#words[@]}; i++ )); do
        word="${words[$i]}"
        
        if [[ "$word" =~ [0-9] || "$word" == *"/"* || "$word" == *"|"* || "$word" == *">"* ]]; then
            suggestion="$word"
        else
            clean_word=$(echo "$word" | sed 's/[^a-zA-ZĂ Ă¨Ă©Ă¬Ă²Ă¹Ă€ĂˆĂ‰ĂŒĂ’Ă™]//g')
            lower_word=$(echo "$clean_word" | tr '[:upper:]' '[:lower:]')
            
            suggestion=""
            if [[ -n "${manual_fixes[$lower_word]}" ]]; then
                suggestion="${manual_fixes[$lower_word]}"
            elif [[ ${#clean_word} -gt 2 ]]; then
                check=$(echo "$clean_word" | aspell -a -l "$lang" 2>/dev/null | grep -E '^\*|^\+')
                if [[ -z "$check" ]]; then
                    raw_sug=$(echo "$clean_word" | aspell -a -l "$lang" --sug-mode=normal 2>/dev/null | grep '&' | awk -F': ' '{print $2}' | cut -d',' -f1 | sed 's/^[[:space:]]*//')
                    [ -n "$raw_sug" ] && suggestion="$raw_sug" || suggestion="$clean_word"
                else
                    suggestion="$clean_word"
                fi
            else
                suggestion="$clean_word"
            fi
            punct=$(echo "$word" | sed 's/[a-zA-ZĂ Ă¨Ă©Ă¬Ă²Ă¹Ă€ĂˆĂ‰ĂŒĂ’Ă™]//g')
            suggestion="${suggestion}${punct}"
        fi

        [ -z "$suggestion" ] && suggestion="$word"

        if [[ $i -eq 0 && ! "$suggestion" =~ ^(git|sudo|python|bash|reboot|grep|demo|daje|ghe|bae|si)$ ]]; then
            suggestion="$(tr '[:lower:]' '[:upper:]' <<< ${suggestion:0:1})${suggestion:1}"
        fi

        if [[ "${suggestion,,}" != "${word,,}" ]]; then
            corrected_text="${corrected_text}${YELLOW}${suggestion}${NC} "
            ((error_count++))
            echo -e "${RED}[FIX]${NC} '$word' -> '${suggestion}'" >&2
        else
            corrected_text="${corrected_text}${suggestion} "
        fi
    done

    echo -e "\n${CYAN}--- TESTO FINALE ---${NC}"
    echo -e "$corrected_text" | sed 's/[[:space:]]*$//'
    echo -e "\n${BLUE}Totale correzioni effettuate: $error_count${NC}"
}

# --- ESECUZIONE ---
echo -e "${BLUE}Lingua (1: it, 2: en, 3: ve):${NC}"
read -p "> " lang_choice

case "$lang_choice" in
    2) LANG="en" ;;
    3) LANG="it" ; echo -e "${GREEN}[MODALITĂ€ VECIO ATTIVATA]${NC}" ;;
    *) LANG="it" ;;
esac

echo -n "Testo: "
read -r user_input
# Passiamo anche lang_choice alla funzione
[ -n "$user_input" ] && solve_typing_issues "$user_input" "$LANG" "$lang_choice"
